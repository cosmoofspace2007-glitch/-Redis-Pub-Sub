@Component
public class PromotionSubscriber
        implements MessageListener {

    @Autowired
    private CacheManager cacheManager;

    @Override
    public void onMessage(
            Message message,
            byte[] pattern) {

        String productId =
                new String(message.getBody());

        Cache cache =
                cacheManager.getCache("products");

        if(cache!=null){

            cache.evict(productId);

            System.out.println(
                    "Đã xóa cache sản phẩm "
                    + productId);

        }

    }

}
